{
  "name": "daddys-dictionary",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:pages": "node scripts/build-pages.mjs",
    "generate:data": "node scripts/generate-data.mjs",
    "generate:data:textbook-expressions": "node scripts/generate-textbook-expressions.mjs",
    "generate:data:example-sentences": "node scripts/generate-example-sentences.mjs",
    "import:data:supplemental": "python3 scripts/import-wordbook-xls.py",
    "check:data": "node scripts/check-data.mjs",
    "check:data:strict": "node scripts/check-data.mjs --strict",
    "check:data:partial": "node scripts/check-data.mjs --partial",
    "test:data": "node --test",
    "test:e2e": "playwright test",
    "verify": "npm run test:data && npm run check:data && npm run build:pages && npm run test:e2e"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
